{
  "name": "market-assassin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "bash tests/run-all-tests.sh",
    "test:pre-deploy": "bash tests/test-pre-deploy.sh",
    "test:local": "bash tests/test-pre-deploy.sh --local",
    "test:schema": "node tests/test-schema-sync.js",
    "verify:data": "npx tsx scripts/verify-data-truth.ts",
    "audit:api-auth": "node scripts/audit-api-auth.js",
    "launch:brief": "node scripts/generate-launch-manager-brief.js",
    "seo:contractor-candidates": "node scripts/generate-seo-contractor-candidates.js",
    "predeploy": "npm run test:schema && npm run test:pre-deploy && npm run verify:data",
    "deploy": "npm run predeploy && vercel --prod",
    "experiment:dry-run": "DRY_RUN=true npx tsx scripts/assign-experiment-cohorts.ts",
    "experiment:execute": "DRY_RUN=false npx tsx scripts/assign-experiment-cohorts.ts",
    "rag:repair:dry-run": "node scripts/repair-rag-corpus.js",
    "rag:repair:apply": "node scripts/repair-rag-corpus.js --apply",
    "rag:templates:dry-run": "node scripts/ingest-proposal-template-corpus.js",
    "rag:templates:apply": "node scripts/ingest-proposal-template-corpus.js --apply"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-cloud/bigquery": "^8.3.1",
    "@google-cloud/storage": "^7.19.0",
    "@supabase/supabase-js": "^2.90.0",
    "@tanstack/react-query": "^5.100.9",
    "@upstash/qstash": "^2.11.0",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "docx": "^9.6.1",
    "driver.js": "^1.4.0",
    "jspdf": "^4.0.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.1.1",
    "nodemailer": "^7.0.12",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "stripe": "^20.1.0",
    "twilio": "^5.12.2",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^27.3.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
