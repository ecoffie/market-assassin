{
  "name": "market-assassin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "bash tests/run-all-tests.sh",
    "test:pre-deploy": "bash tests/test-pre-deploy.sh",
    "test:local": "bash tests/test-pre-deploy.sh --local",
    "test:schema": "node tests/test-schema-sync.js",
    "predeploy": "npm run test:schema && npm run test:pre-deploy",
    "deploy": "npm run predeploy && vercel --prod",
    "experiment:dry-run": "DRY_RUN=true npx tsx scripts/assign-experiment-cohorts.ts",
    "experiment:execute": "DRY_RUN=false npx tsx scripts/assign-experiment-cohorts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/supabase-js": "^2.90.0",
    "@vercel/kv": "^3.0.0",
    "jspdf": "^4.0.0",
    "next": "16.1.1",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.6.0",
    "resend": "^6.10.0",
    "stripe": "^20.1.0",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^27.3.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
