{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "tools.govcongiants.org"
        }
      ],
      "destination": "https://mi.govcongiants.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/dispatch?tick=minute",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/dispatch?tick=hour",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/dispatch?tick=day",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/dispatcher-watchdog",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/founders-seats-refresh",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "10 23 * * 0"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "20 23 * * 0"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "30 23 * * 0"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "40 23 * * 0"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "50 23 * * 0"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "10 0 * * 1"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "20 0 * * 1"
    },
    {
      "path": "/api/cron/weekly-alerts?catchup=true",
      "schedule": "30 0 * * 1"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "10 7 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "20 7 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "40 7 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "50 7 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "10 8 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "20 8 * * *"
    },
    {
      "path": "/api/cron/send-briefings-fast",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "0 7 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "10 7 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "20 7 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
