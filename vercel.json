      "schedule": "50 7 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "0 8 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "10 8 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "20 8 * * 5"
    },
    {
      "path": "/api/cron/send-weekly-fast?catchup=true",
      "schedule": "30 8 * * 5"
    }
  ]
}
