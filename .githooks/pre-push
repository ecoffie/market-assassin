#!/usr/bin/env bash
#
# Pre-push safety gate. HARD-BLOCKS a push when the build would break or a new
# unauthenticated gated fetch slips in — the two failure classes that reached
# prod this week (a broken `getMIApiHeaders` deploy + the "Missing two-factor
# session" auth-header class). Slower/flakier checks WARN but never block.
#
# Enabled via `core.hooksPath=.githooks` (set by `npm run hooks:install`, and
# auto-run on `npm install` via the prepare script). Bypass in a real emergency
# with `git push --no-verify` (use sparingly — it exists for genuine hotfixes).

set -uo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

BOLD='\033[1m'; RED='\033[0;31m'; GREEN='\033[0;32m'; YEL='\033[0;33m'; NC='\033[0m'
fail=0

echo -e "${BOLD}── pre-push gate ──${NC}"

# 1) HARD BLOCK: TypeScript must compile. (Would have blocked today's Error deploy.)
echo -e "  ${BOLD}1/6${NC} typecheck (tsc --noEmit)…"
if npx tsc --noEmit > /tmp/mindy-prepush-tsc.log 2>&1; then
  echo -e "      ${GREEN}✓ typecheck clean${NC}"
else
  echo -e "      ${RED}✗ typecheck FAILED — push blocked${NC}"
  grep "error TS" /tmp/mindy-prepush-tsc.log | head -15 | sed 's/^/        /'
  fail=1
fi

# 2) HARD BLOCK: no NEW unauthenticated fetch to a 2FA-gated /api/app route.
echo -e "  ${BOLD}2/6${NC} client auth-header audit…"
if node scripts/audit-client-auth.mjs > /tmp/mindy-prepush-auth.log 2>&1; then
  echo -e "      ${GREEN}✓ no new unauthenticated gated fetches${NC}"
else
  echo -e "      ${RED}✗ new unauthenticated gated fetch — push blocked${NC}"
  cat /tmp/mindy-prepush-auth.log | sed 's/^/        /'
  fail=1
fi

# 3) HARD BLOCK: no NEW swallowed-error Supabase read (hardcoded multi-column
#    .select() whose { error } is ignored → a bad column silently nulls the whole
#    query → generic/empty result for the user). This is the loadBidderProfile /
#    user_briefing_profile dead-table class. Baseline-gated: only NEW ones block.
echo -e "  ${BOLD}3/6${NC} supabase swallowed-error audit…"
if node scripts/audit-supabase-errors.mjs > /tmp/mindy-prepush-sberr.log 2>&1; then
  echo -e "      ${GREEN}✓ no new swallowed-error reads${NC}"
else
  echo -e "      ${RED}✗ new swallowed-error read — push blocked${NC}"
  cat /tmp/mindy-prepush-sberr.log | sed 's/^/        /'
  fail=1
fi

# 4) HARD BLOCK: unit tests (Vitest). Fast (<1s) + deterministic, so safe to gate.
#    Locks the $674B NAICS-inflation fix, win-probability scoring, authedFetch retry.
echo -e "  ${BOLD}4/6${NC} unit tests (vitest run)…"
if npm run --silent test:unit > /tmp/mindy-prepush-unit.log 2>&1; then
  echo -e "      ${GREEN}✓ unit tests pass${NC}"
else
  echo -e "      ${RED}✗ unit tests FAILED — push blocked${NC}"
  grep -E "✗|FAIL|Error|expected|AssertionError" /tmp/mindy-prepush-unit.log | head -15 | sed 's/^/        /'
  fail=1
fi

# 5) WARN ONLY: schema-sync drift (slower, can lag DB; never blocks a hotfix).
echo -e "  ${BOLD}5/6${NC} schema-sync (warn only)…"
if npm run --silent test:schema > /tmp/mindy-prepush-schema.log 2>&1; then
  echo -e "      ${GREEN}✓ schema in sync${NC}"
else
  echo -e "      ${YEL}⚠ schema-sync reported drift (not blocking — review /tmp/mindy-prepush-schema.log)${NC}"
fi

# 5) WARN ONLY: design-token drift (new arbitrary [#hex] / raw slate-gray colors).
#    Phase 1 of de-vibe-coding: freezes the baseline (135 hex + 10,563 raw-neutral)
#    so the count can only trend DOWN as later phases migrate. Warn-only — never
#    blocks a hotfix; a false positive shouldn't gate a genuine fix while the large
#    baseline still exists. Accept an intentional change with --update-baseline.
echo -e "  ${BOLD}6/6${NC} design-token drift (warn only)…"
if node scripts/audit-design-tokens.mjs > /tmp/mindy-prepush-tokens.log 2>&1; then
  echo -e "      ${GREEN}✓ no new color drift${NC}"
else
  echo -e "      ${YEL}⚠ new raw color(s) added — prefer semantic tokens (bg-surface/border-hairline/text-muted/bg-navy/text-accent):${NC}"
  grep -E ": \+" /tmp/mindy-prepush-tokens.log | head -8 | sed 's/^/        /'
  echo -e "      ${YEL}  (not blocking — see /tmp/mindy-prepush-tokens.log; accept with: node scripts/audit-design-tokens.mjs --update-baseline)${NC}"
fi

if [ "$fail" -ne 0 ]; then
  echo -e "${RED}${BOLD}✗ push blocked by pre-push gate.${NC} Fix the above, or \`git push --no-verify\` for a genuine emergency."
  exit 1
fi
echo -e "${GREEN}${BOLD}✓ pre-push gate passed.${NC}"
exit 0
